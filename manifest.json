{
  "manifest_version": 3,
  "name": "Social Links Manager",
  "version": "1.0",
  "description": "Save and copy your social profile links quickly.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Social Links"
  },
  "permissions": ["storage", "clipboardWrite"],
  "icons": {
    "16": "Icons/16.png",
    "32": "Icons/32.png",
    "48": "Icons/48.png",
    "128": "Icons/128.png"
  }
}

